lsblk -f /dev/nvme1n1

echo "=== 2. PV / VG / LV ==="
pvs
vgs
lvs -a -o +devices

echo "=== 3. Точки монтирования и fstab ==="
df -hT | grep -E "lab-|btrfs|zfs"
cat /etc/fstab

echo "=== 4. lab-root (демонстрация уменьшения до 8G) ==="
lvs lab-vg/lab-root

echo "=== 5. lab-var mirror ==="
lvs -a -o +devices lab-vg/lab-var

echo "=== 6. Состояние home после merge снапшота ==="
ls -lh /mnt/lab-home
lvs -a lab-vg

echo "=== 7. btrfs + LVM cache ==="
lvs -a -o +devices btrfs-vg
btrfs subvolume list /opt/btrfs
ls /opt/btrfs/subvol1-snap

echo "=== 8. ZFS + L2ARC cache ==="
zpool status labtank
zfs list -t snapshot
cat /opt/zfs/test.txt

exit
